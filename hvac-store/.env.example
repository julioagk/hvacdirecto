# Example env for local development and Vite build-time variables.
# Copy this to .env.local and fill real values for local testing.
# For production, set these in the Vercel Project Settings (do NOT commit secrets).
VITE_API_BASE_URL=https://hvacdirecto-production.up.railway.app
VITE_FRONTEND_URL=https://your-vercel-app.vercel.app

# Optional placeholders
# VITE_SENTRY_DSN=
# VITE_OTHER_PUBLIC_KEY=
# Frontend (Vercel)
VITE_APP_NAME=HvacDirecto
VITE_API_BASE_URL=https://tu-backend-en-railway.up.railway.app
VITE_FRONTEND_URL=https://tu-frontend-en-vercel.vercel.app
